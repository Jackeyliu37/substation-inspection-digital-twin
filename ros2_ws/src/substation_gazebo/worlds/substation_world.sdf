    <model name="meter-pressure-01"><static>true</static><pose>4 3 1.35 0 1.57079632679 0</pose><link name="dial"><visual name="case"><geometry><cylinder><radius>0.18</radius><length>0.08</length></cylinder></geometry><material><diffuse>0.90 0.90 0.86 1</diffuse></material></visual><visual name="needle"><pose>0 0.05 0 0 0 0</pose><geometry><box><size>0.015 0.14 0.01</size></box></geometry><material><diffuse>0.8 0.05 0.03 1</diffuse></material></visual></link></model>
