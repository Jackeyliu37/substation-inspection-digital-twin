        <visual name="south_visual"><pose>0 -5.9 0.6 0 0 0</pose><geometry><box><size>16 0.2 1.2</size></box></geometry><material><diffuse>0.18 0.24 0.28 1</diffuse></material></visual>
        <visual name="east_visual"><pose>7.9 0 0.6 0 0 0</pose><geometry><box><size>0.2 12 1.2</size></box></geometry><material><diffuse>0.18 0.24 0.28 1</diffuse></material></visual>
        <visual name="west_visual"><pose>-7.9 0 0.6 0 0 0</pose><geometry><box><size>0.2 12 1.2</size></box></geometry><material><diffuse>0.18 0.24 0.28 1</diffuse></material></visual>
      </link>
    </model>
    <model name="inspection_lane_ns"><static>true</static><pose>0 0 0.061 0 0 0</pose><link name="mark"><visual name="visual"><geometry><box><size>1.5 11.4 0.01</size></box></geometry><material><diffuse>0.78 0.72 0.24 1</diffuse></material></visual></link></model>
