<?xml version="1.0"?>
<sdf version="1.10">
  <world name="substation">
    <physics name="fast_ode" type="ignored">
      <max_step_size>0.001</max_step_size><real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors"><render_engine>ogre2</render_engine></plugin>
    <scene><ambient>0.45 0.45 0.45 1</ambient><background>0.55 0.70 0.85 1</background><shadows>true</shadows></scene>
    <light name="sun" type="directional"><cast_shadows>true</cast_shadows><pose>0 0 10 0 0 0</pose><diffuse>0.9 0.9 0.85 1</diffuse><specular>0.2 0.2 0.2 1</specular><direction>-0.4 0.2 -1</direction></light>

    <model name="yard_ground">
      <static>true</static><link name="ground">
        <collision name="collision"><geometry><box><size>16 12 0.1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>16 12 0.1</size></box></geometry><material><ambient>0.34 0.36 0.36 1</ambient><diffuse>0.42 0.44 0.44 1</diffuse></material></visual>
      </link>
    </model>
    <model name="perimeter_wall">
      <static>true</static><link name="walls">
        <collision name="north"><pose>0 5.9 0.6 0 0 0</pose><geometry><box><size>16 0.2 1.2</size></box></geometry></collision>
        <collision name="south"><pose>0 -5.9 0.6 0 0 0</pose><geometry><box><size>16 0.2 1.2</size></box></geometry></collision>
        <collision name="east"><pose>7.9 0 0.6 0 0 0</pose><geometry><box><size>0.2 12 1.2</size></box></geometry></collision>
        <collision name="west"><pose>-7.9 0 0.6 0 0 0</pose><geometry><box><size>0.2 12 1.2</size></box></geometry></collision>
