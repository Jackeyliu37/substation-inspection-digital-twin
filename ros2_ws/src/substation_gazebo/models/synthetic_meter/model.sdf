<?xml version="1.0"?>
<sdf version="1.10">
  <model name="synthetic_meter">
    <static>false</static>
    <allow_auto_disable>false</allow_auto_disable>
    <link name="case_link">
      <gravity>false</gravity><kinematic>true</kinematic>
      <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <visual name="case"><geometry><cylinder><radius>0.205</radius><length>0.055</length></cylinder></geometry><material><diffuse>0.08 0.09 0.10 1</diffuse><specular>0.25 0.25 0.25 1</specular></material></visual>
      <visual name="face"><pose>0 0 0.031 0 0 0</pose><geometry><cylinder><radius>0.18</radius><length>0.008</length></cylinder></geometry><material><diffuse>0.94 0.93 0.86 1</diffuse><ambient>0.75 0.75 0.70 1</ambient></material></visual>
      <visual name="hub"><pose>0 0 0.041 0 0 0</pose><geometry><cylinder><radius>0.018</radius><length>0.016</length></cylinder></geometry><material><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      <visual name="tick_00"><pose>0 0.145 0.041 0 0 0</pose><geometry><box><size>0.012 0.045 0.008</size></box></geometry><material><diffuse>0.04 0.04 0.04 1</diffuse></material></visual>
      <visual name="tick_03"><pose>0.145 0 0.041 0 0 1.57079632679</pose><geometry><box><size>0.012 0.045 0.008</size></box></geometry><material><diffuse>0.04 0.04 0.04 1</diffuse></material></visual>
      <visual name="tick_06"><pose>0 -0.145 0.041 0 0 0</pose><geometry><box><size>0.012 0.045 0.008</size></box></geometry><material><diffuse>0.04 0.04 0.04 1</diffuse></material></visual>
      <visual name="tick_09"><pose>-0.145 0 0.041 0 0 1.57079632679</pose><geometry><box><size>0.012 0.045 0.008</size></box></geometry><material><diffuse>0.04 0.04 0.04 1</diffuse></material></visual>
    </link>
    <link name="needle_link">
      <gravity>false</gravity>
      <inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <visual name="needle"><pose>0 0.075 0.052 0 0 0</pose><geometry><box><size>0.012 0.15 0.008</size></box></geometry><material><diffuse>0.82 0.03 0.02 1</diffuse><emissive>0.12 0 0 1</emissive></material></visual>
    </link>
    <joint name="needle_joint" type="revolute">
      <parent>case_link</parent><child>needle_link</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-2.5</lower><upper>2.5</upper><effort>10</effort><velocity>20</velocity></limit><dynamics><damping>0.2</damping></dynamics></axis>
    </joint>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>needle_joint</joint_name><p_gain>8</p_gain><i_gain>0.1</i_gain><d_gain>0.2</d_gain><cmd_max>20</cmd_max><cmd_min>-20</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>meter_dataset/joint_states</topic>
    </plugin>
  </model>
</sdf>
